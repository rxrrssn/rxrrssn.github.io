---
const allOrgs = [
  "Colorado Technical University",
  "Salt Lake Community College",
  "Lecanto High School",
  "Apple",
  "Nike",
  
  "node",

  "css",
  "tailwind",
  "sass",
  "bootstrap",

  "mongo",
  "firebase",
  "mysql",

  "cloudflare",

  "figma",
  "vercel",
  "netlify",
  
  "git",
  "markdown",

  "php",
  "wordpress",
];

import Capsule from "../ui/Capsule.astro";

type orgVariant = "default" | "center";

// Base classes that are common to all variants
const baseClasses = "flex flex-wrap gap-4 max-lg:gap-1 grid-auto-efe";

// Variant-specific classes
const variantClasses: Record<orgVariant, string> = {
  default: "cursor-default",
  center: "justify-center cursor-default",
};

const { variant = "default", linkEnabled = false, size = "md" } = Astro.props;

// Combine base classes with variant-specific classes
const classes = `${baseClasses} ${variantClasses[variant as orgVariant]}`;
---

<div class={classes}>
  {allOrgs.map((org) => <Capsule lang={org} linkEnabled={linkEnabled} size={size} />)}
</div>
